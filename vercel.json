{
  "functions": {
    "api/*.js": {
      "maxDuration": 120
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://getbizidea.com/$1",
      "permanent": false,
      "has": [{ "type": "host", "value": "app.getbizidea.com" }]
    },
    {
      "source": "/(.*)",
      "destination": "https://getbizidea.com/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.getbizidea.com" }]
    },
    {
      "source": "/(.*)",
      "destination": "https://getbizidea.com/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "getbizidea.io" }]
    },
    {
      "source": "/(.*)",
      "destination": "https://getbizidea.com/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.getbizidea.io" }]
    }
  ]
}
