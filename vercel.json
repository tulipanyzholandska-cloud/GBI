{
  "functions": {
    "api/*.js": {
      "maxDuration": 120
    }
  },
  "redirects": [
    {
      "source": "/",
      "destination": "https://getbizidea.com",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.getbizidea.com" }]
    },
    {
      "source": "/",
      "destination": "https://getbizidea.com",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.getbizidea.io" }]
    },
    {
      "source": "/",
      "destination": "https://getbizidea.com",
      "permanent": true,
      "has": [{ "type": "host", "value": "getbizidea.io" }]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/quiz.html",
      "has": [{ "type": "host", "value": "app.getbizidea.com" }]
    }
  ]
}
